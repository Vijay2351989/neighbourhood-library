<?xml version="1.0"?>
<!--
    Local-dev ClickHouse user config for SigNoz.

    This file is mounted into the ClickHouse container at
    /etc/clickhouse-server/users.d/library.xml so the default user can be
    used without a password from the SigNoz services on the same compose
    network. Hardening (passwords, IP restrictions) is a deployment-time
    concern; for local dev nothing reaches ClickHouse from outside compose.
-->
<clickhouse>
    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
            <named_collection_control>1</named_collection_control>
            <show_named_collections>1</show_named_collections>
            <show_named_collections_secrets>1</show_named_collections_secrets>
        </default>
    </users>
</clickhouse>
