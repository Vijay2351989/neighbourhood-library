<?xml version="1.0"?>
<!--
    Defines a single-node ClickHouse cluster named "cluster". The SigNoz
    schema migrator defaults to cluster-name=cluster and refuses to create
    the signoz_traces / signoz_logs / signoz_metrics databases without one.

    For local dev we run a single-node setup, so the cluster is one shard
    with one replica pointing back at this same container.
-->
<clickhouse>
    <remote_servers>
        <cluster>
            <shard>
                <replica>
                    <host>signoz-clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </cluster>
    </remote_servers>
    <zookeeper>
        <node>
            <host>signoz-zookeeper</host>
            <port>2181</port>
        </node>
    </zookeeper>
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
    <!--
        Required by SigNoz's `signoz-telemetrystore-migrator`, which creates
        ReplicatedReplacingMergeTree tables whose ZK paths reference
        {shard} and {replica}. Without these macros the bootstrap fails with
        "No macro 'shard' in config".
    -->
    <macros>
        <shard>01</shard>
        <replica>signoz-clickhouse</replica>
        <cluster>cluster</cluster>
    </macros>
</clickhouse>
