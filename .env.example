# =============================================================================
# Neighborhood Library — environment variable template
# =============================================================================
#
# How to use this file:
#
#   1. Copy it to `.env` (which is gitignored):
#        cp .env.example .env
#
#   2. Edit `.env` to override defaults for your local environment.
#      Anything you DON'T set falls back to the default (shown beside `=` below).
#
#   3. `docker compose up` automatically loads `.env` from the repo root.
#      For Path B (local dev without Docker), `source .env` before running
#      the backend, OR copy the relevant sections to `backend/.env` (which
#      `pydantic-settings` will pick up via python-dotenv).
#
# Every value below is a working default — you don't need to change ANY of
# them to bring up a vanilla stack. Override only what you're tuning.

# -----------------------------------------------------------------------------
# Postgres (used by the postgres service in docker-compose)
# -----------------------------------------------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=library

# -----------------------------------------------------------------------------
# Backend — gRPC server
# -----------------------------------------------------------------------------

# SQLAlchemy connection URL. Note the `+asyncpg` driver suffix — the app
# uses asyncpg, not psycopg2.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/library

# Port the Python gRPC server listens on inside the container.
# Compose maps this to host port 50051.
GRPC_PORT=50051

# -----------------------------------------------------------------------------
# Backend — loan / fine policy
# -----------------------------------------------------------------------------
# These knobs are most useful during development:
#   - Set DEFAULT_LOAN_DAYS=0 to make every new loan immediately overdue.
#   - Set FINE_GRACE_DAYS=0 + FINE_PER_DAY_CENTS=100 to surface fine UI fast.

DEFAULT_LOAN_DAYS=14
FINE_GRACE_DAYS=14
FINE_PER_DAY_CENTS=25
FINE_CAP_CENTS=2000

# -----------------------------------------------------------------------------
# Backend — DEMO_MODE
# -----------------------------------------------------------------------------
# When "true", entrypoint.sh truncates all tables and reseeds via
# scripts/reset_and_seed.py BEFORE the gRPC server starts. The seed produces
# 21 books, 10 members, 11 loans (including 2 with computed fines).
#
# Use this when you want a populated UI for visual / Playwright testing.
# Leave at "false" for a production-style empty database.
#
# Reseed runs on EVERY container start when DEMO_MODE=true, so any data the
# librarian entered is wiped. Don't enable in a deployment where you care
# about durable data.

DEMO_MODE=false

# -----------------------------------------------------------------------------
# Backend — DB resilience tuning
# -----------------------------------------------------------------------------
# These bound how long the backend will wait on the database before giving up.
#
# Critical invariant: DB_LOCK_TIMEOUT_MS < DB_STATEMENT_TIMEOUT_MS.
# If lock_timeout >= statement_timeout, lock contention surfaces as the
# ambiguous STATEMENT_TIMEOUT error (NOT retried by RETRY_WRITE_TX) instead
# of the cleaner LOCK_TIMEOUT (which IS retried). The engine logs a warning
# at startup if you violate this.
#
# Lowering these is useful when surfacing timeout / retry behavior in tests:

DB_STATEMENT_TIMEOUT_MS=5000
DB_LOCK_TIMEOUT_MS=3000
DB_IDLE_TX_TIMEOUT_MS=15000
DB_COMMAND_TIMEOUT_S=5

# Connection pool sizing. Set DB_POOL_SIZE=1 + DB_POOL_TIMEOUT_S=1 to
# reproduce pool-exhaustion behavior locally.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_S=5
DB_POOL_RECYCLE_S=1800

# -----------------------------------------------------------------------------
# Backend — observability (OpenTelemetry)
# -----------------------------------------------------------------------------
# Defaults emit traces and logs to stdout (`console` exporter). Useful during
# dev — you see RPC trace events in the api logs.
#
# Set OTEL_TRACES_EXPORTER=none to silence them entirely.
# Set OTEL_TRACES_EXPORTER=otlp + OTEL_EXPORTER_OTLP_ENDPOINT to ship to
# SigNoz (use `docker compose --profile observability up`).

OTEL_SERVICE_NAME=library-api
OTEL_RESOURCE_ATTRIBUTES=service.namespace=library,deployment.environment=local
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_EXPORTER=console
OTEL_LOGS_EXPORTER=console
OTEL_METRICS_EXPORTER=none
OTEL_PROPAGATORS=tracecontext,baggage

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# URL the browser uses to reach Envoy (the gRPC-Web bridge). The web service
# reads this at build time / dev-server start time.
#
# Default points at the dev stack's Envoy listener. Override to:
#   - http://localhost:8081  → talk to the test stack (./test.sh stack)
#   - https://your-staging-host.example.com  → talk to a remote backend

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
